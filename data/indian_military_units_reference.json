        "fauji = soldier / military person",
        "paltan = regiment/battalion (colloquial)",
        "camp = temporary military location"
      ]
    },
    "whatsapp_conventions": {
      "_doc": "Common conventions in WhatsApp messages",
      "patterns": [
        "Numbers before unit names: '20 jak', '107 bde', '3 fd regt'",
        "All lowercase common: 'stn hq', 'jak rif', 'fd wk sp'",
        "ALL CAPS sometimes: 'EME', 'ASC', 'BSF', 'JAK'",
        "Mixed case: 'Stn Hq', 'Fd Regt'",
        "Unit + location: '107 bde guwahati', 'stn hq narangi'",
        "Shorthand for battalion: 'bn', 'battn'",
        "Shorthand: 'adj' or 'adjt' for adjutant",
        "Dropped words: '20 jak' instead of '20 jak rif' or '20th bn jak rif'",
        "Person+unit: 'CO 20 jak', 'QM 107 bde', 'Adjt stn hq'",
        "Supply context: 'indent from 107 bde', 'order for mh', 'supply to fd wk sp'",
        "Assamese context: 'ar' means Assam Rifles in NE, could be ambiguous"
      ]
    }
  },

