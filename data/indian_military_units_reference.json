  "regex_patterns": {
    "_doc": "Ready-to-use regex patterns for entity extraction (Python re syntax, case-insensitive)",
    "numbered_unit": "\\b(\\d{1,3})\\s*(?:jak\\s*(?:rif)?|assam|naga|gorkha|rajput|sikh|dogra|kumaon|mahar|jat|gren|maratha|madras|punjab|bihar|guards|mech\\s*inf|para|ar|bn|bde|bgde|div|divn|regt|rgt|corps|sqn|bty|coy|fd\\s*regt|med\\s*regt|hy\\s*regt|mtn\\s*regt|ad\\s*regt|armd\\s*regt|engr\\s*regt|sig\\s*regt|fd\\s*wk\\s*sp|fd\\s*wksp|fd\\s*amb)\\b",

    "named_unit_no_number": "\\b(?:stn\\s*hq|sub\\s*area|area\\s*hq|command\\s*hq|cmd\\s*hq|base\\s*wk\\s*sp|base\\s*wksp|base\\s*workshop|mh|ch|bh|fh|csd|mes|cantt|garrison)\\b",

    "service_corps": "\\b(?:eme|asc|aoc|amc|adc|aec|apc|cmp|rvc|mes|jag)\\b",

    "capf_units": "\\b(?:(?:\\d{1,3}\\s*(?:bn|battn)\\s*)?(?:bsf|crpf|cisf|itbp|ssb|nsg|rpf|rpsf|assam\\s*rifles|ar))\\b",

    "officer_title_unit": "\\b(?:co|2ic|adjt|qm|bm|goc|cdr|comdt|sc|oic)\\s+(?:\\d{1,3}\\s+)?(?:jak|bde|regt|div|stn\\s*hq|sub\\s*area|mh|ar|assam|gorkha|para)\\b",

    "rank_prefix": "\\b(?:gen|lt\\s*gen|maj\\s*gen|brig|col|lt\\s*col|maj|capt|lt|sub\\s*maj|sub|nb\\s*sub|hav|nk|lnk|sep|gnr|spr|rfn|sigmn|cfn|dvr)\\s+",

    "police_rank": "\\b(?:dgp|adgp|igp|dig|sp|dysp|dy\\s*sp|dsp|ci|si|asi|hc|sho|oc|ic)\\b",

    "artillery_specific": "\\b(?:sata|fd\\s*regt|med\\s*regt|hy\\s*regt|mtn\\s*regt|ad\\s*regt|loc\\s*bty|obs\\s*bty|rocket\\s*regt|missile\\s*regt)\\b",

    "ne_location_military": "\\b(?:narangi|basistha|tezpur|missamari|rangapahar|dimapur|kohima|imphal|leimakhong|lokra|siliguri|sukna|binnaguri|hashimara|umroi|dinjan|jorhat|shillong|bagdogra|bengdubi|panagarh)\\b",

    "informal_hindi_suffix": "(?:jak|bde|regt|stn\\s*hq|mh|ar|cantt)\\s*(?:wala|wale|ke|ka|ki|se|mein|ko|pe)\\b",

    "supply_context": "\\b(?:indent|supply|ration|stores|provisions|demand|issue|receipt|challan)\\s+(?:from|to|for|of)\\s+(?:\\d{1,3}\\s+)?(?:jak|bde|regt|stn|mh|ar|unit)\\b"
  },

