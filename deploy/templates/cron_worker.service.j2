[Unit]
Description=Mantri Cron Worker
After=network.target redis.service
Requires=redis.service

[Service]
Type=simple
User={{ app_user }}
WorkingDirectory={{ app_dir }}
EnvironmentFile=/etc/mantri/secrets.env
Environment=REDIS_URL={{ redis_url }}
Environment=DB_PATH={{ db_path }}
Environment=CRON_INTERVAL_SECONDS={{ cron_interval_seconds }}
ExecStart={{ venv_dir }}/bin/python -m src.alerts.cron_worker
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=mantri-cron

[Install]
WantedBy=multi-user.target
