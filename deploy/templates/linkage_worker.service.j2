[Unit]
Description=Mantri Linkage Worker
After=network.target redis.service
Requires=redis.service

[Service]
Type=simple
User=root
WorkingDirectory={{ app_dir }}
EnvironmentFile=/etc/mantri/secrets.env
Environment=REDIS_URL={{ redis_url }}
Environment=DB_PATH={{ db_path }}
Environment=TASK_EVENTS_STREAM={{ task_events_stream }}
Environment=CLAUDE_MODEL={{ claude_model }}
ExecStart={{ venv_dir }}/bin/python -m src.linkage.linkage_worker
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=mantri-linkage

[Install]
WantedBy=multi-user.target
