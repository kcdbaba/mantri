tests/runs/unit/*.json
tests/runs/incremental/*.json
tests/runs/eval/*.json
tests/runs/integration/*.json

# Integration test artifacts — ephemeral and short-trace outputs
tests/integration_tests/*/replay_progress.json
tests/integration_tests/*/routing_mismatches.json
tests/integration_tests/*/replay_result_short.json
tests/integration_tests/*/replay_result_short.db
