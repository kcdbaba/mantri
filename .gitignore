# Test run records — now tracked for portal reproducibility
# (previously gitignored; small files 0.5-2.5KB each)

# Dev mode artifacts
tests/integration_tests/*/replay_result_dev.*
tests/integration_tests/*/pipeline_score_dev.json

# Test pipeline state (local, not shared)
.test-state/

# Integration test artifacts — ephemeral and short-trace outputs
tests/integration_tests/*/replay_progress.json
tests/integration_tests/*/routing_mismatches.json
tests/integration_tests/*/replay_result_short.json
tests/integration_tests/*/replay_result_short.db
tests/integration_tests/*/pipeline_score_short.json
.coverage
